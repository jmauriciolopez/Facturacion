# =============================================
# tax-ar-service — Variables de entorno
# Copiar a .env.local para desarrollo local
# =============================================

# App
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL=postgresql://taxar:taxar@localhost:5432/taxar_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Seguridad del microservicio
# Claves separadas por coma — los sistemas cliente deben enviar una de estas en x-api-key
API_KEY_HEADER=x-api-key
VALID_API_KEYS=changeme-key-1,changeme-key-2

# Ambiente fiscal AFIP/ARCA
# true = homologación, false = producción
FISCAL_HOMOLOGATION=true

# Clave de cifrado para certificados (mín. 32 chars, usar un secret manager en prod)
ENCRYPTION_SECRET=change-me-to-a-32-char-secret!!
